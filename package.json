{
  "name": "razertraybattery",
  "version": "1.0.1",
  "main": "src/main.js",
  "author": "jozefwitek",
  "license": "ISC",
  "description": "Shows razer's battery on tray",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:win": "electron-forge package --platform=win32 --arch=x64",
    "make:win": "npm run package:win && powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./build-installer.ps1",
    "make": "electron-forge make"
  },
  "config": {
    "forge": {
      "rebuildConfig": {
        "ignoreModules": [
          "node-hid",
          "usb"
        ]
      },
      "packagerConfig": {
        "icon": "src/assets/generated/battery.ico"
      }
    }
  },
  "dependencies": {
    "canvas": "^3.2.0",
    "electron-squirrel-startup": "^1.0.0",
    "node-hid": "^3.2.0",
    "usb": "^2.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.4.2",
    "@electron-forge/maker-deb": "^6.0.4",
    "@electron-forge/maker-rpm": "^6.0.4",
    "@electron-forge/maker-squirrel": "^6.4.2",
    "@electron-forge/maker-zip": "^6.0.4",
    "electron": "^22.0.0"
  }
}
